@page "/"

<PageTitle>RelayChat</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-6">
    <MudStack Spacing="3">
        <MudText Typo="Typo.h3">RelayChat</MudText>
        <MudText Typo="Typo.body1">Select a server and channel to open chat.</MudText>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
        }
        else if (_servers.Count == 0)
        {
            <MudText Typo="Typo.body2">No servers available.</MudText>
        }
        else
        {
            @foreach (var server in _servers)
            {
                <MudPaper Class="pa-4" Outlined="true">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h5">@server.Name</MudText>

                        @if (_channelsByServer.TryGetValue(server.Id, out var channels) && channels.Count > 0)
                        {
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                @foreach (var channel in channels)
                                {
                                    <MudChip T="string"
                                             Href="@GetChannelHref(server.Id, channel.Id)"
                                             Variant="Variant.Outlined"
                                             Color="Color.Primary">
                                        #@channel.Name
                                    </MudChip>
                                }
                            </MudStack>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">No channels available.</MudText>
                        }
                    </MudStack>
                </MudPaper>
            }
        }
    </MudStack>
</MudContainer>
