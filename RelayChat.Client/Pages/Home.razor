@page "/"

<PageTitle>RelayChat</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">
    <MudStack Spacing="3">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h3">RelayChat</MudText>
            <MudText Typo="Typo.body1">This client connects to a single node. Join it, then open a channel.</MudText>
        </MudStack>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
        }
        else
        {
            <MudGrid Spacing="3">
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 h-100" Outlined="true">
                        <MudStack Spacing="2">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.h5">@_nodeName</MudText>
                                <MudText Typo="Typo.body2">
                                    Role: @(_membership is null ? (_isAuthenticated ? "Not joined" : "Sign in required") : _membership.Role)
                                </MudText>
                            </MudStack>

                            @if (!_isAuthenticated)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           OnClick="Login">
                                    Login
                                </MudButton>
                            }
                            else if (_membership is null)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           OnClick="JoinNode">
                                    Join Node
                                </MudButton>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Success">You can open channels on this node.</MudAlert>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-4 h-100" Outlined="true">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6">Channels</MudText>

                            @if (_channels.Count == 0)
                            {
                                <MudText Typo="Typo.body2">No channels available.</MudText>
                            }
                            else
                            {
                                <MudList T="string">
                                    @foreach (var channel in _channels)
                                    {
                                        <MudListItem T="string"
                                                     Href="@GetChannelHref(channel.Id)"
                                                     Icon="@Icons.Material.Rounded.Tag"
                                                     Class="mb-1">
                                            <MudText>#@channel.Name</MudText>
                                        </MudListItem>
                                    }
                                </MudList>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12">
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudStack Spacing="3">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.h6">Profile</MudText>
                                <MudText Typo="Typo.body2">Set the name people see, your unique handle, and an avatar URL.</MudText>
                            </MudStack>

                            @if (!_isAuthenticated)
                            {
                                <MudAlert Severity="Severity.Info">Sign in to manage your profile.</MudAlert>
                            }
                            else
                            {
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="4">
                                        <MudTextField @bind-Value="_profileName"
                                                      Label="Display name"
                                                      Variant="Variant.Outlined"
                                                      FullWidth="true" />
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudTextField @bind-Value="_profileHandle"
                                                      Label="Handle"
                                                      Variant="Variant.Outlined"
                                                      FullWidth="true" />
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudTextField @bind-Value="_profileAvatarUrl"
                                                      Label="Avatar URL"
                                                      Variant="Variant.Outlined"
                                                      FullWidth="true" />
                                    </MudItem>
                                </MudGrid>

                                @if (!string.IsNullOrWhiteSpace(_profileEmail))
                                {
                                    <MudText Typo="Typo.body2">Email: @_profileEmail</MudText>
                                }

                                @if (!string.IsNullOrWhiteSpace(_profileStatusMessage))
                                {
                                    <MudAlert Severity="Severity.Success">@_profileStatusMessage</MudAlert>
                                }
                                @if (!string.IsNullOrWhiteSpace(_profileErrorMessage))
                                {
                                    <MudAlert Severity="Severity.Error">@_profileErrorMessage</MudAlert>
                                }

                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               OnClick="SaveProfile">
                                        Save Profile
                                    </MudButton>
                                    @if (!string.IsNullOrWhiteSpace(_profilePreviewHandle))
                                    {
                                        <MudText Typo="Typo.body2">@($"Preview: {_profileName} (@{_profilePreviewHandle})")</MudText>
                                    }
                                </MudStack>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </MudStack>
</MudContainer>
