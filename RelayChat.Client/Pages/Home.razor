@page "/"
@page "/servers/{ServerId:guid}"

<PageTitle>RelayChat</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <MudStack Spacing="3">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h3">RelayChat</MudText>
            <MudText Typo="Typo.body1">Choose a server, then open a channel.</MudText>
        </MudStack>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
        }
        else
        {
            <MudGrid Spacing="3">
                <MudItem xs="12" md="4" lg="3">
                    <MudPaper Class="pa-3 h-100" Outlined="true">
                        <MudText Typo="Typo.h6" Class="mb-2">Servers</MudText>

                        @if (_servers.Count == 0)
                        {
                            <MudText Typo="Typo.body2">No servers available.</MudText>
                        }
                        else
                        {
                            <MudList T="string">
                                @foreach (var server in _servers)
                                {
                                    <MudListItem T="string"
                                                 Href="@GetServerHref(server.Id)"
                                                 Icon="@Icons.Material.Rounded.Dns"
                                                 Class="mb-1">
                                        <MudText Color="@(server.Id == _selectedServer?.Id ? Color.Primary : Color.Inherit)">
                                            @server.Name
                                        </MudText>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="8" lg="9">
                    <MudPaper Class="pa-4 h-100" Outlined="true">
                        @if (_selectedServer is null)
                        {
                            <MudText Typo="Typo.body2">Select a server to view channels.</MudText>
                        }
                        else
                        {
                            <MudStack Spacing="2">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.h5">@_selectedServer.Name</MudText>
                                    <MudText Typo="Typo.body2">Channels</MudText>
                                </MudStack>

                                @if (_selectedChannels.Count == 0)
                                {
                                    <MudText Typo="Typo.body2">No channels available.</MudText>
                                }
                                else
                                {
                                    <MudList T="string">
                                        @foreach (var channel in _selectedChannels)
                                        {
                                            <MudListItem T="string"
                                                         Href="@GetChannelHref(_selectedServer.Id, channel.Id)"
                                                         Icon="@Icons.Material.Rounded.Tag"
                                                         Class="mb-1">
                                                <MudText>#@channel.Name</MudText>
                                            </MudListItem>
                                        }
                                    </MudList>
                                }
                            </MudStack>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </MudStack>
</MudContainer>
