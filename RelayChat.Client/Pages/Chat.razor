@page "/servers/{ServerId:guid}/channels/{ChannelId:guid}"

<PageTitle>Chat</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <MudGrid Spacing="3">
        <MudItem xs="12" md="3" lg="2">
            <MudPaper Class="pa-3 h-100" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-2">Servers</MudText>

                <MudList T="string">
                    @foreach (var server in _servers)
                    {
                        <MudListItem T="string"
                                     Href="@GetServerHref(server)"
                                     Icon="@Icons.Material.Rounded.Dns"
                                     Class="mb-1">
                            <MudText Color="@(server.Id == ServerId ? Color.Primary : Color.Inherit)">
                                @server.Name
                            </MudText>
                        </MudListItem>
                    }
                </MudList>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4" lg="3">
            <MudPaper Class="pa-3 h-100" Outlined="true">
                <MudStack Spacing="2">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6">@_serverName</MudText>
                        <MudText Typo="Typo.body2">Channels</MudText>
                    </MudStack>

                    <MudList T="string">
                        @foreach (var channel in _channels)
                        {
                            <MudListItem T="string"
                                         Href="@GetChannelHref(channel)"
                                         Icon="@Icons.Material.Rounded.Tag"
                                         Class="mb-1">
                                <MudText Color="@(channel.Id == _channelId ? Color.Primary : Color.Inherit)">
                                    #@channel.Name
                                </MudText>
                            </MudListItem>
                        }
                    </MudList>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="5" lg="7">
            <MudStack Spacing="3">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h4">@_serverName</MudText>
                        <MudText Typo="Typo.body1">#@_channelName</MudText>
                    </MudStack>
                </MudPaper>

                <MudPaper Class="pa-4" Outlined="true">
                    <MudStack Spacing="2">
                        @if (_messages.Count == 0)
                        {
                            <MudText Typo="Typo.body2">No messages yet.</MudText>
                        }
                        else
                        {
                            @foreach (var message in _messages)
                            {
                                <MudPaper Class="pa-3" Outlined="true">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.caption">@message.Message.AuthorId</MudText>
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@GetStateColor(message.State)">
                                                @message.State
                                            </MudChip>
                                        </MudStack>
                                        <MudText Typo="Typo.body1">@message.Message.Content</MudText>
                                        <MudText Typo="Typo.caption">@message.Message.CreatedAt.ToLocalTime().ToString("u")</MudText>
                                    </MudStack>
                                </MudPaper>
                            }
                        }
                    </MudStack>
                </MudPaper>

                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                    <MudTextField @bind-Value="_messageText"
                                  Label="Message"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Immediate="true"
                                  OnKeyDown="HandleKeyDown" />
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="SendMessage"
                               Disabled="@string.IsNullOrWhiteSpace(_messageText)">
                        Send
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudContainer>
