@page "/"
@page "/channels/{ChannelId:guid}"

<PageTitle>Relay</PageTitle>

<div class="relay-shell @(_isVoiceChannel ? "relay-shell--voice" : string.Empty)">
    <div class="relay-left-panel">
        <aside class="relay-server-rail">
            <button type="button" class="relay-rail-button relay-rail-button--primary" @onclick="NoOp">
                <MudIcon Icon="@Icons.Material.Rounded.AlternateEmail" />
                <span>DMs</span>
            </button>

            <div class="relay-rail-divider"></div>

            @if (_hasServer)
            {
                <a href="@GetServerHref()" class="relay-server-pill relay-server-pill--active" draggable="true">
                    <span>@_serverInitial</span>
                </a>
            }

            <button type="button" class="relay-server-pill relay-server-pill--action" @onclick="NoOp">
                <MudIcon Icon="@Icons.Material.Rounded.Add" />
            </button>

            <button type="button" class="relay-server-pill relay-server-pill--action" @onclick="NoOp">
                <MudIcon Icon="@Icons.Material.Rounded.TravelExplore" />
            </button>
        </aside>

        <section class="relay-sidebar">
            <div class="relay-sidebar__grow">
                <div class="relay-sidebar__header">
                    <div>
                        <div class="relay-eyebrow">Server</div>
                        <h1>@(_hasServer ? _nodeName : "No Servers")</h1>
                    </div>
                    @if (_membershipRole is not null)
                    {
                        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">@_membershipRole</MudChip>
                    }
                </div>

                @if (!_isAuthenticated)
                {
                    <div class="relay-empty-panel">
                        <p>Sign in to access your servers.</p>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Login">Login</MudButton>
                    </div>
                }
                else if (!_hasServer)
                {
                    <div class="relay-empty-panel">
                        <p>You are in no servers.</p>
                        <MudText Typo="Typo.body2">This client is currently connected to a single node called <strong>@_nodeName</strong>.</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="JoinNode">Join Server</MudButton>
                    </div>
                }
                else
                {
                    @if (_canCreateChannels)
                    {
                        <div class="relay-channel-create">
                            <MudTextField @bind-Value="_newChannelName"
                                          Label="New channel"
                                          Variant="Variant.Outlined"
                                          FullWidth="true" />
                            <MudSelect T="ChannelType"
                                       @bind-Value="_newChannelType"
                                       Label="Type"
                                       Variant="Variant.Outlined">
                                <MudSelectItem Value="@ChannelType.Text">Text</MudSelectItem>
                                <MudSelectItem Value="@ChannelType.Voice">Voice</MudSelectItem>
                            </MudSelect>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="CreateChannel"
                                       Disabled="@string.IsNullOrWhiteSpace(_newChannelName)">
                                Add Channel
                            </MudButton>
                        </div>
                    }

                    <div class="relay-channel-list">
                        @foreach (var channel in _channels)
                        {
                            var voiceParticipants = channel.Type == ChannelType.Voice
                                ? GetVoiceParticipantsForChannel(channel.Id)
                                : [];

                            if (_isVoiceChannel && VoiceClient.ActiveChannelId == channel.Id)
                            {
                                <div class="relay-channel-item relay-channel-item--active"
                                     draggable="@_canReorderChannels"
                                     @ondragstart="@(() => BeginChannelDrag(channel.Id))"
                                     @ondragover:preventDefault
                                     @ondrop="@(() => DropChannel(channel.Id))">
                                    <div class="relay-channel-item__row">
                                        <div class="relay-channel-item__icon">
                                            <MudIcon Icon="@GetChannelIcon(channel)" />
                                        </div>
                                        <span>@GetChannelLabel(channel)</span>
                                    </div>
                                    @if (voiceParticipants.Count > 0)
                                    {
                                        <div class="relay-voice-member-list">
                                            @foreach (var participant in voiceParticipants)
                                            {
                                                <div class="relay-voice-member-row"
                                                     @oncontextmenu:preventDefault="@(!IsCurrentUser(participant.UserId))"
                                                     @oncontextmenu="@(args => IsCurrentUser(participant.UserId) ? Task.CompletedTask : OpenVoiceRowVolumeMenu(args, participant))">
                                                    <div class="relay-voice-member-avatar @(IsVoiceParticipantSpeaking(participant.UserId) ? "relay-voice-member-avatar--speaking" : string.Empty)">
                                                        @if (!string.IsNullOrWhiteSpace(participant.AvatarUrl))
                                                        {
                                                            <img src="@participant.AvatarUrl" alt="@participant.Name" />
                                                        }
                                                        else
                                                        {
                                                            <span>@GetVoiceParticipantInitial(participant)</span>
                                                        }
                                                    </div>
                                                    <span class="relay-voice-member-name">@participant.Name</span>
                                                    <div class="relay-voice-member-status">
                                                        @if (participant.IsMuted)
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Rounded.MicOff" Size="Size.Small" />
                                                        }
                                                        @if (participant.IsDeafened)
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Rounded.HeadsetOff" Size="Size.Small" />
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <a href="@GetChannelHref(channel)"
                                   class="relay-channel-item @(IsCurrentChannel(channel) ? "relay-channel-item--active" : string.Empty)"
                                   draggable="@_canReorderChannels"
                                   @ondragstart="@(() => BeginChannelDrag(channel.Id))"
                                   @ondragover:preventDefault
                                   @ondrop="@(() => DropChannel(channel.Id))">
                                    <div class="relay-channel-item__row">
                                        <div class="relay-channel-item__icon">
                                            <MudIcon Icon="@GetChannelIcon(channel)" />
                                        </div>
                                        <span>@GetChannelLabel(channel)</span>
                                    </div>
                                    @if (voiceParticipants.Count > 0)
                                    {
                                        <div class="relay-voice-member-list">
                                            @foreach (var participant in voiceParticipants)
                                            {
                                                <div class="relay-voice-member-row"
                                                     @oncontextmenu:preventDefault="@(!IsCurrentUser(participant.UserId))"
                                                     @oncontextmenu="@(args => IsCurrentUser(participant.UserId) ? Task.CompletedTask : OpenVoiceRowVolumeMenu(args, participant))">
                                                    <div class="relay-voice-member-avatar @(IsVoiceParticipantSpeaking(participant.UserId) ? "relay-voice-member-avatar--speaking" : string.Empty)">
                                                        @if (!string.IsNullOrWhiteSpace(participant.AvatarUrl))
                                                        {
                                                            <img src="@participant.AvatarUrl" alt="@participant.Name" />
                                                        }
                                                        else
                                                        {
                                                            <span>@GetVoiceParticipantInitial(participant)</span>
                                                        }
                                                    </div>
                                                    <span class="relay-voice-member-name">@participant.Name</span>
                                                    <div class="relay-voice-member-status">
                                                        @if (participant.IsMuted)
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Rounded.MicOff" Size="Size.Small" />
                                                        }
                                                        @if (participant.IsDeafened)
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Rounded.HeadsetOff" Size="Size.Small" />
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </a>
                            }
                        }
                    </div>
                }
            </div>
        </section>

        @if (_showConnectedVoicePanel)
        {
            <div class="relay-voice-connection-panel">
                <div class="relay-voice-connection-panel__status">
                    <div class="relay-voice-connection-panel__indicator">
                        <MudIcon Icon="@Icons.Material.Rounded.Wifi" />
                        <span>Voice Connected</span>
                    </div>
                    <div class="relay-voice-connection-panel__channel">@ActiveVoiceChannel!.Name</div>
                </div>
                <div class="relay-voice-connection-panel__actions">
                    <MudIconButton Icon="@(_isCameraEnabled ? Icons.Material.Rounded.Videocam : Icons.Material.Rounded.VideocamOff)"
                                   Size="Size.Small"
                                   Color="@(_isCameraEnabled ? Color.Success : Color.Default)"
                                   OnClick="ToggleCamera" />
                    <MudIconButton Icon="@(_isScreenShareEnabled ? Icons.Material.Rounded.StopScreenShare : Icons.Material.Rounded.ScreenShare)"
                                   Size="Size.Small"
                                   Color="@(_isScreenShareEnabled ? Color.Success : Color.Default)"
                                   OnClick="ToggleScreenShare" />
                    <MudIconButton Icon="@Icons.Material.Rounded.CallEnd"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="DisconnectVoice" />
                </div>
            </div>
        }

        <div class="relay-user-pane">
            <button type="button" class="relay-user-pane__main" @onclick="OpenSettings">
                <div class="relay-user-pane__avatar">
                    @if (!string.IsNullOrWhiteSpace(_currentUserAvatarUrl))
                    {
                        <img src="@_currentUserAvatarUrl" alt="@_currentUserName" />
                    }
                    else
                    {
                        <span>@_currentUserInitial</span>
                    }
                </div>
                <div class="relay-user-pane__body">
                    <span class="relay-user-pane__name">@_currentUserName</span>
                    <span class="relay-user-pane__handle">@($"@{_currentUserHandle}")</span>
                </div>
            </button>
            <div class="relay-user-pane__actions">
                <MudIconButton Icon="@(_isVoiceMuted ? Icons.Material.Rounded.MicOff : Icons.Material.Rounded.Mic)"
                               Size="Size.Small"
                               Color="@(_isVoiceMuted ? Color.Warning : Color.Default)"
                               OnClick="TogglePreferredMute" />
                <MudIconButton Icon="@(_isVoiceDeafened ? Icons.Material.Rounded.HeadsetOff : Icons.Material.Rounded.Headset)"
                               Size="Size.Small"
                               Color="@(_isVoiceDeafened ? Color.Error : Color.Default)"
                               OnClick="TogglePreferredDeafen" />
                <MudIconButton Icon="@Icons.Material.Rounded.Settings"
                               Size="Size.Small"
                               Color="Color.Default"
                               OnClick="OpenSettings" />
            </div>
        </div>
    </div>

    <main class="relay-content">
        @if (!_isAuthenticated)
        {
            <div class="relay-state-card">
                <h2>Sign in to open Relay.</h2>
                <p>Authentication is handled by the control plane through Authentik.</p>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Login">Login</MudButton>
            </div>
        }
        else if (!_hasServer)
        {
            <div class="relay-state-card">
                <h2>You are in no servers.</h2>
                <p>Join <strong>@_nodeName</strong> to open channels, text chat, and voice.</p>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="JoinNode">Join Server</MudButton>
            </div>
        }
        else if (!_hasChannels)
        {
            <div class="relay-state-card">
                <h2>No channels yet.</h2>
                <p>Create a text or voice channel to get started.</p>
            </div>
        }
        else if (_isVoiceChannel)
        {
            <div class="relay-voice-header">
                <MudIcon Icon="@Icons.Material.Rounded.VolumeUp" Size="Size.Medium" />
                <h2>@_currentChannelName</h2>
            </div>

            <div class="relay-voice-stage">
                @if (_voiceTiles.Count == 0)
                {
                    <div class="relay-empty-messages">
                        <p>Nobody is connected yet.</p>
                    </div>
                }
                else if (_focusedVoiceTile is not null)
                {
                    <div class="relay-voice-layout relay-voice-layout--focused">
                        <div class="relay-voice-focus-area">
                            <div class="relay-voice-tile relay-voice-tile--focused @(_focusedVoiceTile.Kind == VoiceTileKind.Screen ? "relay-voice-tile--screen" : string.Empty) @(ShowVoiceTileSpeaking(_focusedVoiceTile) ? "relay-voice-tile--speaking" : string.Empty)"
                                 @onclick="@(() => ToggleVoiceTileFocus(_focusedVoiceTile))"
                                 @oncontextmenu:preventDefault="@(!_focusedVoiceTile.IsCurrentUser)"
                                 @oncontextmenu="@(args => _focusedVoiceTile.IsCurrentUser ? Task.CompletedTask : OpenVoiceTileVolumeMenu(args, _focusedVoiceTile))">
                                <div class="relay-voice-tile__media">
                                    @if (_focusedVoiceTile.HasVideo)
                                    {
                                        <div id="@GetVoiceTileVideoElementId(_focusedVoiceTile)" class="relay-voice-tile__video-host"></div>
                                    }
                                    else
                                    {
                                        <div class="relay-voice-tile__placeholder">
                                            @if (!string.IsNullOrWhiteSpace(_focusedVoiceTile.AvatarUrl))
                                            {
                                                <img src="@_focusedVoiceTile.AvatarUrl" alt="@_focusedVoiceTile.DisplayName" />
                                            }
                                            else
                                            {
                                                <span>@GetVoiceTileInitial(_focusedVoiceTile)</span>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="relay-voice-tile__footer">
                                    <div class="relay-voice-tile__name">@GetVoiceTileTitle(_focusedVoiceTile)</div>
                                    <div class="relay-voice-tile__badges">
                                        @if (_focusedVoiceTile.Kind == VoiceTileKind.Screen)
                                        {
                                            <span class="relay-voice-badge relay-voice-badge--screen">
                                                <MudIcon Icon="@Icons.Material.Rounded.ScreenShare" Size="Size.Small" />
                                            </span>
                                        }
                                        @if (ShowVoiceTileMute(_focusedVoiceTile))
                                        {
                                            <span class="relay-voice-badge relay-voice-badge--mute">
                                                <MudIcon Icon="@Icons.Material.Rounded.MicOff" Size="Size.Small" />
                                            </span>
                                        }
                                        @if (ShowVoiceTileDeafen(_focusedVoiceTile))
                                        {
                                            <span class="relay-voice-badge relay-voice-badge--deafen">
                                                <MudIcon Icon="@Icons.Material.Rounded.HeadsetOff" Size="Size.Small" />
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (_secondaryVoiceTiles.Count > 0 && !_areSecondaryVoiceTilesCollapsed)
                        {
                            <div class="relay-voice-secondary-panel">
                                <button type="button"
                                    class="relay-voice-secondary-toggle"
                                    @onclick="@(() => SetSecondaryVoiceTilesCollapsed(true))">
                                    <MudIcon Icon="@Icons.Material.Rounded.KeyboardArrowDown" Size="Size.Small" />
                                    <MudIcon Icon="@Icons.Material.Rounded.Groups" Size="Size.Small" />
                                </button>

                                <div class="relay-voice-secondary-strip">
                                    @foreach (var tile in _secondaryVoiceTiles)
                                    {
                                        <div class="relay-voice-tile relay-voice-tile--compact @(tile.Kind == VoiceTileKind.Screen ? "relay-voice-tile--screen" : string.Empty) @(ShowVoiceTileSpeaking(tile) ? "relay-voice-tile--speaking" : string.Empty)"
                                             @onclick="@(() => ToggleVoiceTileFocus(tile))"
                                             @oncontextmenu:preventDefault="@(!tile.IsCurrentUser)"
                                             @oncontextmenu="@(args => tile.IsCurrentUser ? Task.CompletedTask : OpenVoiceTileVolumeMenu(args, tile))">
                                            <div class="relay-voice-tile__media">
                                                @if (tile.HasVideo)
                                                {
                                                    <div id="@GetVoiceTileVideoElementId(tile)" class="relay-voice-tile__video-host"></div>
                                                }
                                                else
                                                {
                                                    <div class="relay-voice-tile__placeholder relay-voice-tile__placeholder--compact">
                                                        @if (!string.IsNullOrWhiteSpace(tile.AvatarUrl))
                                                        {
                                                            <img src="@tile.AvatarUrl" alt="@tile.DisplayName" />
                                                        }
                                                        else
                                                        {
                                                            <span>@GetVoiceTileInitial(tile)</span>
                                                        }
                                                    </div>
                                                }
                                            </div>

                                            <div class="relay-voice-tile__footer">
                                                <div class="relay-voice-tile__name">@GetVoiceTileTitle(tile)</div>
                                                <div class="relay-voice-tile__badges">
                                                    @if (tile.Kind == VoiceTileKind.Screen)
                                                    {
                                                        <span class="relay-voice-badge relay-voice-badge--screen">
                                                            <MudIcon Icon="@Icons.Material.Rounded.ScreenShare" Size="Size.Small" />
                                                        </span>
                                                    }
                                                    @if (ShowVoiceTileMute(tile))
                                                    {
                                                        <span class="relay-voice-badge relay-voice-badge--mute">
                                                            <MudIcon Icon="@Icons.Material.Rounded.MicOff" Size="Size.Small" />
                                                        </span>
                                                    }
                                                    @if (ShowVoiceTileDeafen(tile))
                                                    {
                                                        <span class="relay-voice-badge relay-voice-badge--deafen">
                                                            <MudIcon Icon="@Icons.Material.Rounded.HeadsetOff" Size="Size.Small" />
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else if (_secondaryVoiceTiles.Count > 0)
                        {
                            <div class="relay-voice-secondary-panel relay-voice-secondary-panel--collapsed">
                                <button type="button"
                                        class="relay-voice-secondary-toggle"
                                        @onclick="@(() => SetSecondaryVoiceTilesCollapsed(false))">
                                    <MudIcon Icon="@Icons.Material.Rounded.KeyboardArrowUp" Size="Size.Small" />
                                    <MudIcon Icon="@Icons.Material.Rounded.Groups" Size="Size.Small" />
                                </button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="relay-voice-grid @(_voiceTiles.Count == 1 ? "relay-voice-grid--single" : string.Empty)">
                        @foreach (var tile in _voiceTiles)
                        {
                            <div class="relay-voice-tile @(tile.Kind == VoiceTileKind.Screen ? "relay-voice-tile--screen" : string.Empty) @(ShowVoiceTileSpeaking(tile) ? "relay-voice-tile--speaking" : string.Empty)"
                                 @onclick="@(() => ToggleVoiceTileFocus(tile))"
                                 @oncontextmenu:preventDefault="@(!tile.IsCurrentUser)"
                                 @oncontextmenu="@(args => tile.IsCurrentUser ? Task.CompletedTask : OpenVoiceTileVolumeMenu(args, tile))">
                                <div class="relay-voice-tile__media">
                                    @if (tile.HasVideo)
                                    {
                                        <div id="@GetVoiceTileVideoElementId(tile)" class="relay-voice-tile__video-host"></div>
                                    }
                                    else
                                    {
                                        <div class="relay-voice-tile__placeholder">
                                            @if (!string.IsNullOrWhiteSpace(tile.AvatarUrl))
                                            {
                                                <img src="@tile.AvatarUrl" alt="@tile.DisplayName" />
                                            }
                                            else
                                            {
                                                <span>@GetVoiceTileInitial(tile)</span>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="relay-voice-tile__footer">
                                    <div class="relay-voice-tile__name">@GetVoiceTileTitle(tile)</div>
                                    <div class="relay-voice-tile__badges">
                                        @if (tile.Kind == VoiceTileKind.Screen)
                                        {
                                            <span class="relay-voice-badge relay-voice-badge--screen">
                                                <MudIcon Icon="@Icons.Material.Rounded.ScreenShare" Size="Size.Small" />
                                            </span>
                                        }
                                        @if (ShowVoiceTileMute(tile))
                                        {
                                            <span class="relay-voice-badge relay-voice-badge--mute">
                                                <MudIcon Icon="@Icons.Material.Rounded.MicOff" Size="Size.Small" />
                                            </span>
                                        }
                                        @if (ShowVoiceTileDeafen(tile))
                                        {
                                            <span class="relay-voice-badge relay-voice-badge--deafen">
                                                <MudIcon Icon="@Icons.Material.Rounded.HeadsetOff" Size="Size.Small" />
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="relay-voice-controls-panel">
                <div class="relay-voice-controls">
                <MudIconButton Icon="@(_isVoiceMuted ? Icons.Material.Rounded.MicOff : Icons.Material.Rounded.Mic)"
                               Size="Size.Medium"
                               Color="@(_isVoiceMuted ? Color.Warning : Color.Default)"
                               OnClick="ToggleMute"
                               Disabled="@(!_isConnectedToVoiceChannel)" />
                <MudIconButton Icon="@(_isVoiceDeafened ? Icons.Material.Rounded.HeadsetOff : Icons.Material.Rounded.Headset)"
                               Size="Size.Medium"
                               Color="@(_isVoiceDeafened ? Color.Error : Color.Default)"
                               OnClick="TogglePreferredDeafen"
                               Disabled="@(!_isConnectedToVoiceChannel)" />
                <MudIconButton Icon="@(_isCameraEnabled ? Icons.Material.Rounded.Videocam : Icons.Material.Rounded.VideocamOff)"
                               Size="Size.Medium"
                               Color="@(_isCameraEnabled ? Color.Success : Color.Default)"
                               OnClick="ToggleCamera"
                               Disabled="@(!_isConnectedToVoiceChannel)" />
                <MudIconButton Icon="@(_isScreenShareEnabled ? Icons.Material.Rounded.StopScreenShare : Icons.Material.Rounded.ScreenShare)"
                               Size="Size.Medium"
                               Color="@(_isScreenShareEnabled ? Color.Success : Color.Default)"
                               OnClick="ToggleScreenShare"
                               Disabled="@(!_isConnectedToVoiceChannel)" />
                <MudIconButton Icon="@Icons.Material.Rounded.CallEnd"
                               Size="Size.Medium"
                               Color="Color.Error"
                               OnClick="DisconnectVoice"
                               Disabled="@(!_isConnectedToVoiceChannel)" />
                </div>
            </div>
        }
        else
        {
            <div class="relay-channel-header">
                <div>
                    <div class="relay-eyebrow">Text Channel</div>
                    <h2>#@_currentChannelName</h2>
                </div>
            </div>

            <div id="@MessageScrollContainerId" class="relay-message-scroll">
                @if (_chatDays.Count == 0)
                {
                    <div class="relay-empty-messages">
                        <p>No messages yet.</p>
                    </div>
                }
                else
                {
                    @foreach (var day in _chatDays)
                    {
                        <div class="relay-day-divider">
                            <span>@GetDisplayDate(day.Day)</span>
                        </div>

                        @foreach (var group in day.Groups)
                        {
                            <article class="relay-message-group">
                                <div class="relay-message-group__avatar">
                                    @if (!string.IsNullOrWhiteSpace(group.AuthorAvatarUrl))
                                    {
                                        <img src="@group.AuthorAvatarUrl" alt="@group.AuthorName" />
                                    }
                                    else
                                    {
                                        <span>@GetMessageGroupInitial(group)</span>
                                    }
                                </div>

                                <div class="relay-message-group__body">
                                    <header class="relay-message-group__header">
                                        <span class="relay-message-group__author">@group.AuthorName</span>
                                        <span class="relay-message-group__timestamp">@group.StartedAt.ToLocalTime().ToString("t")</span>
                                    </header>

                                    <div class="relay-message-group__messages">
                                        @foreach (var message in group.Messages)
                                        {
                                            <div class="relay-message-line">
                                                @if (_editingMessageId == message.Message.Id)
                                                {
                                                    <div class="relay-message-line__edit">
                                                        <MudTextField @bind-Value="_editText"
                                                                      Variant="Variant.Outlined"
                                                                      FullWidth="true"
                                                                      Immediate="true" />
                                                        <div class="relay-message-line__edit-actions">
                                                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEdit">Save</MudButton>
                                                            <MudButton Variant="Variant.Text" OnClick="CancelEdit">Cancel</MudButton>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="relay-message-line__content">@message.Message.Content</div>
                                                }

                                                <div class="relay-message-line__meta">
                                                    @if (!string.IsNullOrWhiteSpace(GetMessageStateLabel(message)))
                                                    {
                                                        <span class="relay-message-line__state">@GetMessageStateLabel(message)</span>
                                                    }
                                                    @if (message.Message.EditedAt.HasValue)
                                                    {
                                                        <span class="relay-message-line__edited">(edited)</span>
                                                    }
                                                    @if (CanEditMessage(message))
                                                    {
                                                        <MudIconButton Icon="@Icons.Material.Rounded.Edit"
                                                                       Size="Size.Small"
                                                                       Color="Color.Default"
                                                                       OnClick="@(() => BeginEdit(message))" />
                                                    }
                                                    @if (CanDeleteMessage(message))
                                                    {
                                                        <MudIconButton Icon="@Icons.Material.Rounded.Delete"
                                                                       Size="Size.Small"
                                                                       Color="Color.Error"
                                                                       OnClick="@(() => DeleteMessage(message))" />
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </article>
                        }
                    }
                }
            </div>

            <div class="relay-composer">
                <textarea id="@ComposerId"
                          class="relay-composer__input"
                          rows="1"
                          placeholder="Message #@_currentChannelName"
                          @bind="_messageText"
                          @bind:event="oninput"></textarea>
            </div>
        }
    </main>

    @if (_showMembersPanel)
    {
        <aside class="relay-members">
            <div class="relay-members__header">
                <div class="relay-eyebrow">Members</div>
                <h2>@(members.Count)</h2>
            </div>

            <div class="relay-members__list">
                @if (!_hasServer)
                {
                    <div class="relay-empty-panel">
                        <p>No server members to show.</p>
                    </div>
                }
                else
                {
                    @foreach (var group in GetMemberGroups())
                    {
                        <section class="relay-member-group">
                            <h3>@GetMemberGroupLabel(group.Key)</h3>

                            @foreach (var member in group)
                            {
                                <div class="relay-member-row">
                                    <div class="relay-member-row__avatar">
                                        @if (!string.IsNullOrWhiteSpace(member.AvatarUrl))
                                        {
                                            <img src="@member.AvatarUrl" alt="@member.Name" />
                                        }
                                        else
                                        {
                                            <span>@GetMemberInitial(member)</span>
                                        }
                                    </div>
                                    <div class="relay-member-row__body">
                                        <span class="relay-member-row__name">@member.Name</span>
                                        <span class="relay-member-row__handle">@($"@{member.Handle}")</span>
                                    </div>
                                </div>
                            }
                        </section>
                    }
                }
            </div>
        </aside>
    }
</div>

@if (_isVoiceVolumeMenuOpen)
{
    <div class="relay-voice-volume-menu-backdrop" @onclick="CloseVoiceVolumeMenu">
        <div class="relay-voice-volume-menu"
             style="@($"left: {_voiceVolumeMenuLeft}px; top: {_voiceVolumeMenuTop}px;")"
             @onclick:stopPropagation>
            <div class="relay-voice-volume-menu__body">
                <MudIcon Icon="@Icons.Material.Rounded.VolumeUp" />
                <input class="relay-voice-volume-menu__slider"
                       type="range"
                       min="0"
                       max="200"
                       step="1"
                       value="@_voiceVolumePercent"
                       @oninput="HandleVoiceVolumeChanged" />
                <span class="relay-voice-volume-menu__value">@($"{_voiceVolumePercent}%")</span>
            </div>
        </div>
    </div>
}

@if (_isSettingsOpen)
{
    <div class="relay-settings-backdrop" @onclick="CloseSettings">
        <div class="relay-settings-modal" @onclick:stopPropagation>
            <div class="relay-settings-modal__header">
                <div>
                    <div class="relay-eyebrow">Settings</div>
                    <h2>Edit Profile</h2>
                </div>
            </div>

            <div class="relay-settings-modal__body">
                <MudTextField @bind-Value="_profileName"
                              Label="Display name"
                              Variant="Variant.Outlined"
                              FullWidth="true" />
                <MudTextField @bind-Value="_profileHandle"
                              Label="Handle"
                              Variant="Variant.Outlined"
                              FullWidth="true" />
                <MudTextField @bind-Value="_profileAvatarUrl"
                              Label="Avatar URL"
                              Variant="Variant.Outlined"
                              FullWidth="true" />

                @if (!string.IsNullOrWhiteSpace(_profileErrorMessage))
                {
                    <MudAlert Severity="Severity.Error">@_profileErrorMessage</MudAlert>
                }
            </div>

            <div class="relay-settings-modal__actions">
                <MudButton Variant="Variant.Text" OnClick="CloseSettings">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings">Save</MudButton>
            </div>
        </div>
    </div>
}
