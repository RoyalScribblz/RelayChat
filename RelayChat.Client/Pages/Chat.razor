@page "/channels/{ChannelId:guid}"

<PageTitle>Chat</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <MudGrid Spacing="3">
        <MudItem xs="12" md="4" lg="3">
            <MudPaper Class="pa-3 h-100" Outlined="true">
                <MudStack Spacing="2">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6">@_nodeName</MudText>
                        <MudText Typo="Typo.body2">
                            Role: @(_isAuthenticated ? (_membershipRole?.ToString() ?? "Not joined") : "Sign in required")
                        </MudText>
                    </MudStack>

                    @if (!_isAuthenticated)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="Login">
                            Login
                        </MudButton>
                    }
                    else if (_membershipRole is null)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="JoinNode">
                            Join Node
                        </MudButton>
                    }

                    @if (_membershipRole == MembershipRole.Admin)
                    {
                        <MudStack Spacing="2">
                            <MudTextField @bind-Value="_newChannelName"
                                          Label="New channel"
                                          Variant="Variant.Outlined"
                                          FullWidth="true" />
                            <MudSelect T="ChannelType"
                                       @bind-Value="_newChannelType"
                                       Label="Channel type"
                                       Variant="Variant.Outlined">
                                <MudSelectItem Value="@ChannelType.Text">Text</MudSelectItem>
                                <MudSelectItem Value="@ChannelType.Voice">Voice</MudSelectItem>
                            </MudSelect>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="CreateChannel"
                                       Disabled="@string.IsNullOrWhiteSpace(_newChannelName)">
                                Add Channel
                            </MudButton>
                        </MudStack>
                    }

                    <MudList T="string">
                        @foreach (var channel in _channels)
                        {
                            <MudListItem T="string"
                                         Href="@GetChannelHref(channel)"
                                         Icon="@GetChannelIcon(channel)"
                                         Class="mb-1">
                                <MudText Color="@(channel.Id == _channelId ? Color.Primary : Color.Inherit)">
                                    @GetChannelLabel(channel)
                                </MudText>
                            </MudListItem>
                        }
                    </MudList>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="@(_isVoiceChannel ? 5 : 8)" lg="@(_isVoiceChannel ? 5 : 9)">
            <MudStack Spacing="3">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h4">@_nodeName</MudText>
                        <MudText Typo="Typo.body1">@(_isVoiceChannel ? _channelName : $"#{_channelName}")</MudText>
                    </MudStack>
                </MudPaper>

                @if (!_isAuthenticated)
                {
                    <MudAlert Severity="Severity.Info">
                        Sign in through the control plane before opening this channel.
                    </MudAlert>
                }
                else if (_membershipRole is null)
                {
                    <MudAlert Severity="Severity.Warning">
                        Join this node before opening channels.
                    </MudAlert>
                }
                else if (_isVoiceChannel)
                {
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudStack Spacing="3">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.h5">Connected To Voice</MudText>
                                <MudText Typo="Typo.body2">
                                    @(_isConnectedToVoiceChannel ? "You are connected to this voice channel." : "Joining voice...")
                                </MudText>
                            </MudStack>

                            <MudStack Row="true" Spacing="2">
                                <MudButton Variant="Variant.Filled"
                                           Color="@(_isVoiceMuted ? Color.Warning : Color.Primary)"
                                           OnClick="ToggleMute"
                                           Disabled="@(!_isConnectedToVoiceChannel)">
                                    @(_isVoiceMuted ? "Unmute" : "Mute")
                                </MudButton>
                                <MudButton Variant="Variant.Filled"
                                           Color="@(_isCameraEnabled ? Color.Secondary : Color.Default)"
                                           OnClick="ToggleCamera"
                                           Disabled="@(!_isConnectedToVoiceChannel)">
                                    @(_isCameraEnabled ? "Camera Off" : "Camera On")
                                </MudButton>
                                <MudButton Variant="Variant.Filled"
                                           Color="@(_isScreenShareEnabled ? Color.Info : Color.Default)"
                                           OnClick="ToggleScreenShare"
                                           Disabled="@(!_isConnectedToVoiceChannel)">
                                    @(_isScreenShareEnabled ? "Stop Sharing" : "Share Screen")
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           OnClick="DisconnectVoice"
                                           Disabled="@(!_isConnectedToVoiceChannel)">
                                    Leave Voice
                                </MudButton>
                            </MudStack>
                            <MudSwitch T="bool"
                                       @bind-Value="_shareScreenWithAudio"
                                       Color="Color.Primary"
                                       Disabled="@(_isScreenShareEnabled)"
                                       Label="Share audio" />
                        </MudStack>
                    </MudPaper>

                    <MudPaper Class="pa-4" Outlined="true">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6">Video</MudText>
                            <div id="livekit-video-grid"
                                 style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;"></div>
                        </MudStack>
                    </MudPaper>
                }
                else
                {
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudStack Spacing="2">
                            @if (_messages.Count == 0)
                            {
                                <MudText Typo="Typo.body2">No messages yet.</MudText>
                            }
                            else
                            {
                                @foreach (var message in _messages)
                                {
                                    <MudPaper Class="pa-3" Outlined="true">
                                        <MudStack Spacing="1">
                                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                <MudText Typo="Typo.caption">@message.Message.AuthorId</MudText>
                                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@GetStateColor(message.State)">
                                                        @message.State
                                                    </MudChip>
                                                    @if (CanEditMessage(message))
                                                    {
                                                        <MudIconButton Icon="@Icons.Material.Rounded.Edit"
                                                                       Size="Size.Small"
                                                                       Color="Color.Default"
                                                                       OnClick="@(() => BeginEdit(message))" />
                                                    }
                                                    @if (CanDeleteMessage(message))
                                                    {
                                                        <MudIconButton Icon="@Icons.Material.Rounded.Delete"
                                                                       Size="Size.Small"
                                                                       Color="Color.Error"
                                                                       OnClick="@(() => DeleteMessage(message))" />
                                                    }
                                                </MudStack>
                                            </MudStack>
                                            @if (_editingMessageId == message.Message.Id)
                                            {
                                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                                                    <MudTextField @bind-Value="_editText"
                                                                  Variant="Variant.Outlined"
                                                                  FullWidth="true"
                                                                  Immediate="true" />
                                                    <MudButton Variant="Variant.Filled"
                                                               Color="Color.Primary"
                                                               OnClick="SaveEdit">
                                                        Save
                                                    </MudButton>
                                                    <MudButton Variant="Variant.Text"
                                                               OnClick="CancelEdit">
                                                        Cancel
                                                    </MudButton>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body1">@GetMessageBody(message)</MudText>
                                            }
                                            <MudStack Row="true" Spacing="1">
                                                <MudText Typo="Typo.caption">@message.Message.CreatedAt.ToLocalTime().ToString("u")</MudText>
                                                @if (message.Message.EditedAt.HasValue)
                                                {
                                                    <MudText Typo="Typo.caption">(edited)</MudText>
                                                }
                                            </MudStack>
                                        </MudStack>
                                    </MudPaper>
                                }
                            }
                        </MudStack>
                    </MudPaper>

                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                        <MudTextField @bind-Value="_messageText"
                                      Label="Message"
                                      Variant="Variant.Outlined"
                                      FullWidth="true"
                                      Immediate="true"
                                      OnKeyDown="HandleKeyDown" />
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="SendMessage"
                                   Disabled="@string.IsNullOrWhiteSpace(_messageText)">
                            Send
                        </MudButton>
                    </MudStack>
                }
            </MudStack>
        </MudItem>

        @if (_isVoiceChannel)
        {
            <MudItem xs="12" md="3" lg="4">
                <MudPaper Class="pa-3 h-100" Outlined="true">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h6">Participants</MudText>

                        @if (_voiceParticipants.Count == 0)
                        {
                            <MudText Typo="Typo.body2">Nobody is connected yet.</MudText>
                        }
                        else
                        {
                            @foreach (var participant in _voiceParticipants)
                            {
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-2">
                                    @if (!string.IsNullOrWhiteSpace(participant.AvatarUrl))
                                    {
                                        <MudAvatar Size="Size.Medium">
                                            <MudImage Src="@participant.AvatarUrl" Alt="@participant.Name" />
                                        </MudAvatar>
                                    }
                                    else
                                    {
                                        <MudAvatar Size="Size.Medium">@GetParticipantInitial(participant)</MudAvatar>
                                    }
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body1">@participant.Name</MudText>
                                        <MudText Typo="Typo.caption">@($"@{participant.Handle}")</MudText>
                                    </MudStack>
                                    @if (IsParticipantSpeaking(participant))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">
                                            Speaking
                                        </MudChip>
                                    }
                                    @if (IsParticipantOnCamera(participant))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                            Camera
                                        </MudChip>
                                    }
                                    @if (participant.IsMuted)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                                            Muted
                                        </MudChip>
                                    }
                                </MudStack>
                            }
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</MudContainer>
