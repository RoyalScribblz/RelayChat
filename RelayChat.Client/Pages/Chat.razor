@page "/"
@page "/channels/{ChannelId:guid}"

<PageTitle>Relay</PageTitle>

<div class="relay-shell @(_isVoiceChannel ? "relay-shell--voice" : string.Empty)">
    <div class="relay-left-panel">
        <aside class="relay-server-rail">
            <button type="button" class="relay-rail-button relay-rail-button--primary" @onclick="NoOp">
                <MudIcon Icon="@Icons.Material.Rounded.AlternateEmail" />
                <span>DMs</span>
            </button>

            <div class="relay-rail-divider"></div>

            @if (_hasServer)
            {
                <a href="@GetServerHref()" class="relay-server-pill relay-server-pill--active" draggable="true">
                    <span>@_serverInitial</span>
                </a>
            }

            <button type="button" class="relay-server-pill relay-server-pill--action" @onclick="NoOp">
                <MudIcon Icon="@Icons.Material.Rounded.Add" />
            </button>

            <button type="button" class="relay-server-pill relay-server-pill--action" @onclick="NoOp">
                <MudIcon Icon="@Icons.Material.Rounded.TravelExplore" />
            </button>
        </aside>

        <section class="relay-sidebar">
            <div class="relay-sidebar__grow">
                <div class="relay-sidebar__header">
                    <div>
                        <div class="relay-eyebrow">Server</div>
                        <h1>@(_hasServer ? _nodeName : "No Servers")</h1>
                    </div>
                    @if (_membershipRole is not null)
                    {
                        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">@_membershipRole</MudChip>
                    }
                </div>

                @if (!_isAuthenticated)
                {
                    <div class="relay-empty-panel">
                        <p>Sign in to access your servers.</p>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Login">Login</MudButton>
                    </div>
                }
                else if (!_hasServer)
                {
                    <div class="relay-empty-panel">
                        <p>You are in no servers.</p>
                        <MudText Typo="Typo.body2">This client is currently connected to a single node called <strong>@_nodeName</strong>.</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="JoinNode">Join Server</MudButton>
                    </div>
                }
                else
                {
                    @if (_canCreateChannels)
                    {
                        <div class="relay-channel-create">
                            <MudTextField @bind-Value="_newChannelName"
                                          Label="New channel"
                                          Variant="Variant.Outlined"
                                          FullWidth="true" />
                            <MudSelect T="ChannelType"
                                       @bind-Value="_newChannelType"
                                       Label="Type"
                                       Variant="Variant.Outlined">
                                <MudSelectItem Value="@ChannelType.Text">Text</MudSelectItem>
                                <MudSelectItem Value="@ChannelType.Voice">Voice</MudSelectItem>
                            </MudSelect>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="CreateChannel"
                                       Disabled="@string.IsNullOrWhiteSpace(_newChannelName)">
                                Add Channel
                            </MudButton>
                        </div>
                    }

                    <div class="relay-channel-list">
                        @foreach (var channel in _channels)
                        {
                            <a href="@GetChannelHref(channel)"
                               class="relay-channel-item @(IsCurrentChannel(channel) ? "relay-channel-item--active" : string.Empty)"
                               draggable="@_canReorderChannels"
                               @ondragstart="@(() => BeginChannelDrag(channel.Id))"
                               @ondragover:preventDefault
                               @ondrop="@(() => DropChannel(channel.Id))">
                                <div class="relay-channel-item__icon">
                                    <MudIcon Icon="@GetChannelIcon(channel)" />
                                </div>
                                <span>@GetChannelLabel(channel)</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </section>

        <div class="relay-user-pane">
            <button type="button" class="relay-user-pane__main" @onclick="OpenSettings">
                <div class="relay-user-pane__avatar">
                    @if (!string.IsNullOrWhiteSpace(_currentUserAvatarUrl))
                    {
                        <img src="@_currentUserAvatarUrl" alt="@_currentUserName" />
                    }
                    else
                    {
                        <span>@_currentUserInitial</span>
                    }
                </div>
                <div class="relay-user-pane__body">
                    <span class="relay-user-pane__name">@_currentUserName</span>
                    <span class="relay-user-pane__handle">@($"@{_currentUserHandle}")</span>
                </div>
            </button>
            <div class="relay-user-pane__actions">
                <MudIconButton Icon="@(_isVoiceMuted ? Icons.Material.Rounded.MicOff : Icons.Material.Rounded.Mic)"
                               Size="Size.Small"
                               Color="@(_isVoiceMuted ? Color.Warning : Color.Default)"
                               OnClick="TogglePreferredMute" />
                <MudIconButton Icon="@(_isVoiceDeafened ? Icons.Material.Rounded.HeadsetOff : Icons.Material.Rounded.Headset)"
                               Size="Size.Small"
                               Color="@(_isVoiceDeafened ? Color.Warning : Color.Default)"
                               OnClick="TogglePreferredDeafen" />
                <MudIconButton Icon="@Icons.Material.Rounded.Settings"
                               Size="Size.Small"
                               Color="Color.Default"
                               OnClick="OpenSettings" />
            </div>
        </div>
    </div>

    <main class="relay-content">
        @if (!_isAuthenticated)
        {
            <div class="relay-state-card">
                <h2>Sign in to open Relay.</h2>
                <p>Authentication is handled by the control plane through Authentik.</p>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Login">Login</MudButton>
            </div>
        }
        else if (!_hasServer)
        {
            <div class="relay-state-card">
                <h2>You are in no servers.</h2>
                <p>Join <strong>@_nodeName</strong> to open channels, text chat, and voice.</p>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="JoinNode">Join Server</MudButton>
            </div>
        }
        else if (!_hasChannels)
        {
            <div class="relay-state-card">
                <h2>No channels yet.</h2>
                <p>Create a text or voice channel to get started.</p>
            </div>
        }
        else if (_isVoiceChannel)
        {
            <div class="relay-channel-header">
                <div>
                    <div class="relay-eyebrow">Voice Channel</div>
                    <h2>@_currentChannelName</h2>
                </div>
            </div>

            <div class="relay-voice-stage">
                <div id="livekit-video-grid" class="relay-voice-grid"></div>
            </div>

            <div class="relay-voice-controls">
                <MudButton Variant="Variant.Filled"
                           Color="@(_isVoiceMuted ? Color.Warning : Color.Primary)"
                           OnClick="ToggleMute"
                           Disabled="@(!_isConnectedToVoiceChannel)">
                    @(_isVoiceMuted ? "Unmute" : "Mute")
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="@(_isCameraEnabled ? Color.Secondary : Color.Default)"
                           OnClick="ToggleCamera"
                           Disabled="@(!_isConnectedToVoiceChannel)">
                    @(_isCameraEnabled ? "Camera Off" : "Camera On")
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="@(_isScreenShareEnabled ? Color.Info : Color.Default)"
                           OnClick="ToggleScreenShare"
                           Disabled="@(!_isConnectedToVoiceChannel)">
                    @(_isScreenShareEnabled ? "Stop Sharing" : "Share Screen")
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Error"
                           OnClick="DisconnectVoice"
                           Disabled="@(!_isConnectedToVoiceChannel)">
                    Leave Call
                </MudButton>
            </div>
        }
        else
        {
            <div class="relay-channel-header">
                <div>
                    <div class="relay-eyebrow">Text Channel</div>
                    <h2>#@_currentChannelName</h2>
                </div>
            </div>

            <div id="@MessageScrollContainerId" class="relay-message-scroll">
                @if (_chatDays.Count == 0)
                {
                    <div class="relay-empty-messages">
                        <p>No messages yet.</p>
                    </div>
                }
                else
                {
                    @foreach (var day in _chatDays)
                    {
                        <div class="relay-day-divider">
                            <span>@GetDisplayDate(day.Day)</span>
                        </div>

                        @foreach (var group in day.Groups)
                        {
                            <article class="relay-message-group">
                                <div class="relay-message-group__avatar">
                                    @if (!string.IsNullOrWhiteSpace(group.AuthorAvatarUrl))
                                    {
                                        <img src="@group.AuthorAvatarUrl" alt="@group.AuthorName" />
                                    }
                                    else
                                    {
                                        <span>@GetMessageGroupInitial(group)</span>
                                    }
                                </div>

                                <div class="relay-message-group__body">
                                    <header class="relay-message-group__header">
                                        <span class="relay-message-group__author">@group.AuthorName</span>
                                        <span class="relay-message-group__timestamp">@group.StartedAt.ToLocalTime().ToString("t")</span>
                                    </header>

                                    <div class="relay-message-group__messages">
                                        @foreach (var message in group.Messages)
                                        {
                                            <div class="relay-message-line">
                                                @if (_editingMessageId == message.Message.Id)
                                                {
                                                    <div class="relay-message-line__edit">
                                                        <MudTextField @bind-Value="_editText"
                                                                      Variant="Variant.Outlined"
                                                                      FullWidth="true"
                                                                      Immediate="true" />
                                                        <div class="relay-message-line__edit-actions">
                                                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEdit">Save</MudButton>
                                                            <MudButton Variant="Variant.Text" OnClick="CancelEdit">Cancel</MudButton>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="relay-message-line__content">@message.Message.Content</div>
                                                }

                                                <div class="relay-message-line__meta">
                                                    @if (!string.IsNullOrWhiteSpace(GetMessageStateLabel(message)))
                                                    {
                                                        <span class="relay-message-line__state">@GetMessageStateLabel(message)</span>
                                                    }
                                                    @if (message.Message.EditedAt.HasValue)
                                                    {
                                                        <span class="relay-message-line__edited">(edited)</span>
                                                    }
                                                    @if (CanEditMessage(message))
                                                    {
                                                        <MudIconButton Icon="@Icons.Material.Rounded.Edit"
                                                                       Size="Size.Small"
                                                                       Color="Color.Default"
                                                                       OnClick="@(() => BeginEdit(message))" />
                                                    }
                                                    @if (CanDeleteMessage(message))
                                                    {
                                                        <MudIconButton Icon="@Icons.Material.Rounded.Delete"
                                                                       Size="Size.Small"
                                                                       Color="Color.Error"
                                                                       OnClick="@(() => DeleteMessage(message))" />
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </article>
                        }
                    }
                }
            </div>

            <div class="relay-composer">
                <textarea id="@ComposerId"
                          class="relay-composer__input"
                          placeholder="Message #@_currentChannelName"
                          @bind="_messageText"
                          @bind:event="oninput"></textarea>
            </div>
        }
    </main>

    @if (_showMembersPanel)
    {
        <aside class="relay-members">
            <div class="relay-members__header">
                <div class="relay-eyebrow">Members</div>
                <h2>@(members.Count)</h2>
            </div>

            <div class="relay-members__list">
                @if (!_hasServer)
                {
                    <div class="relay-empty-panel">
                        <p>No server members to show.</p>
                    </div>
                }
                else
                {
                    @foreach (var group in GetMemberGroups())
                    {
                        <section class="relay-member-group">
                            <h3>@GetMemberGroupLabel(group.Key)</h3>

                            @foreach (var member in group)
                            {
                                <div class="relay-member-row">
                                    <div class="relay-member-row__avatar">
                                        @if (!string.IsNullOrWhiteSpace(member.AvatarUrl))
                                        {
                                            <img src="@member.AvatarUrl" alt="@member.Name" />
                                        }
                                        else
                                        {
                                            <span>@GetMemberInitial(member)</span>
                                        }
                                    </div>
                                    <div class="relay-member-row__body">
                                        <span class="relay-member-row__name">@member.Name</span>
                                        <span class="relay-member-row__handle">@($"@{member.Handle}")</span>
                                    </div>
                                </div>
                            }
                        </section>
                    }
                }
            </div>
        </aside>
    }
</div>

@if (_isSettingsOpen)
{
    <div class="relay-settings-backdrop" @onclick="CloseSettings">
        <div class="relay-settings-modal" @onclick:stopPropagation>
            <div class="relay-settings-modal__header">
                <div>
                    <div class="relay-eyebrow">Settings</div>
                    <h2>Edit Profile</h2>
                </div>
            </div>

            <div class="relay-settings-modal__body">
                <MudTextField @bind-Value="_profileName"
                              Label="Display name"
                              Variant="Variant.Outlined"
                              FullWidth="true" />
                <MudTextField @bind-Value="_profileHandle"
                              Label="Handle"
                              Variant="Variant.Outlined"
                              FullWidth="true" />
                <MudTextField @bind-Value="_profileAvatarUrl"
                              Label="Avatar URL"
                              Variant="Variant.Outlined"
                              FullWidth="true" />

                @if (!string.IsNullOrWhiteSpace(_profileErrorMessage))
                {
                    <MudAlert Severity="Severity.Error">@_profileErrorMessage</MudAlert>
                }
            </div>

            <div class="relay-settings-modal__actions">
                <MudButton Variant="Variant.Text" OnClick="CloseSettings">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings">Save</MudButton>
            </div>
        </div>
    </div>
}
